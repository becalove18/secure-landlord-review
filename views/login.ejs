<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("partials/head", {
    pageTitle: "Login | RentReview"
  }) %>
</head>

<body>
  <%- include("partials/navigation", {
    isLoggedIn: isLoggedIn
  }) %>

  <main class="auth-page">
    <section class="auth-card">
      <p class="section-label">
        WELCOME BACK
      </p>

      <h1>
        Log in to RentReview
      </h1>

      <p class="auth-description">
        Access your account to submit a landlord review.
      </p>

      <form action="/login" method="POST">
        <div class="form-group">
          <label for="email">
            Email Address
          </label>

          <input
            id="email"
            name="email"
            type="email"
            autocomplete="email"
            required
          >
        </div>

        <div class="form-group">
          <label for="password">
            Password
          </label>

          <input
            id="password"
            name="password"
            type="password"
            autocomplete="current-password"
            required
          >
        </div>

        <button
          class="primary-button form-submit-button"
          type="submit"
        >
          Login
        </button>
      </form>

      <p class="auth-switch">
        Do not have an account?
        <a href="/register">Create one here.</a>
      </p>
    </section>
  </main>

  <%- include("partials/footer") %>

  <script src="/script.js" defer></script>
</body>
</html>